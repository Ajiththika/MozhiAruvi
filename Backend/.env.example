# ── Mozhi Aruvi Backend Environment Architecture ─────────────────────────────
# This file serves as the blueprint for production-grade system configuration.
# Copy this to .env and fill in the official production keys.
# ─────────────────────────────────────────────────────────────────────────────

# 1. SERVER CONFIGURATION
PORT=5000
NODE_ENV=production
FRONTEND_ORIGIN=https://mozhiaruvi.com  # Official frontend URL

# 2. DATABASE NODES
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/MozhiArivu

# 3. SECURITY KEYS (JWT)
JWT_ACCESS_SECRET=your_32_char_long_random_string_here
JWT_ACCESS_EXPIRES=7d
REFRESH_EXPIRES_DAYS=7d
BCRYPT_ROUNDS=12

# 4. AI & LINGUISTIC HUB (HUGGING FACE)
# Deployment Model: mistralai/Mistral-7B-Instruct-v0.3
HUGGINGFACE_API_KEY=hf_your_inference_key_here
ADMIN_EMAIL=admin@mozhiaruvi.com

# 5. SMTP EMAIL INFRASTRUCTURE (GMAIL/SENDGRID)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mozhiaruvi@gmail.com
SMTP_PASS=your_app_password  # Do NOT use your real password; use App Passwords
SMTP_FROM="Mozhi Aruvi <mozhiaruvi@gmail.com>"

# 6. EXTERNAL ASSET HUB (CLOUDINARY)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# 7. FINANCIAL ENGINE (STRIPE)
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# STRIPE PRICE NODES (Must match your Stripe Product IDs)
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxxx
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_xxxx
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_xxxx
STRIPE_BUSINESS_30_PRICE_ID=price_xxxx
STRIPE_BUSINESS_60_PRICE_ID=price_xxxx

# 8. GOOGLE OAUTH 2.0 CLOUD
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://api.mozhiaruvi.com/api/auth/google/callback

# Standard Path: ./google-credentials.json (Relative to Backend root)
GOOGLE_APPLICATION_CREDENTIALS="./google-credentials.json"
# 9. GOOGLE GEMINI AI
GEMINI_API_KEY=your_gemini_api_key_here
